# Environment variables template for Habit Tracker Application
# Copy this file to .env and fill in your actual values

# =============================================================================
# MONGODB DATABASE
# =============================================================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-this-secure-password
MONGO_DATABASE=habit_tracker
MONGODB_URI=mongodb://admin:change-this-secure-password@localhost:27017/habit_tracker?authSource=admin

# =============================================================================
# REDIS CACHE (Optional)
# =============================================================================
REDIS_URL=redis://:redis123@localhost:6379
REDIS_PASSWORD=redis123

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate secure random strings for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-at-least-32-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# =============================================================================
# CORS AND FRONTEND URLS
# =============================================================================
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# EMAIL CONFIGURATION (Optional - for password reset, notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@habittracker.com
FROM_NAME=Habit Tracker

# =============================================================================
# FILE UPLOAD CONFIGURATION (Optional - for habit images, exports)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=habit-tracker-uploads

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
# Sentry for error monitoring
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Log level: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your-mixpanel-token

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# Set to true to enable debug mode
DEBUG=false

# Disable authentication in development (DANGEROUS - NEVER USE IN PRODUCTION)
DISABLE_AUTH=false

# =============================================================================
# PRODUCTION VALUES (Examples)
# =============================================================================
# NODE_ENV=production
# CORS_ORIGIN=https://yourdomain.com
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# LOG_LEVEL=error
# DEBUG=false